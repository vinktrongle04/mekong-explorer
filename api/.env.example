# Mekong Explorer Backend API Environment Variables
# Copy this file to .env and fill in your actual values

# ---------------------------------------------------------
# Application Configuration
# ---------------------------------------------------------
PORT=3000
NODE_ENV=development

# ---------------------------------------------------------
# Database (Prisma / PostgreSQL)
# ---------------------------------------------------------
# PostgreSQL connection string to your Supabase or local Docker instance
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mekong_explorer?schema=public"

# ---------------------------------------------------------
# Authentication (JWT)
# ---------------------------------------------------------
# Secret key used to sign and verify JSON Web Tokens. 
# In production, use a long, random, cryptographically secure string!
JWT_SECRET="your_super_secret_jwt_key_here_please_change_for_production"

# ---------------------------------------------------------
# File Storage (AWS S3 or Cloudflare R2)
# ---------------------------------------------------------
# AWS Region (e.g., ap-southeast-1 for Singapore)
AWS_REGION="ap-southeast-1"

# The name of your created S3 bucket
AWS_S3_BUCKET="mekong-explorer-photos"

# IAM User Credentials (ensure they have S3 PutObject permissions)
AWS_ACCESS_KEY_ID="your_aws_access_key_id"
AWS_SECRET_ACCESS_KEY="your_aws_secret_access_key"
