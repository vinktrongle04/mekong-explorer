{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "lib": ["es2020", "dom"],
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@mekong/ui/*": ["packages/ui/src/*"],
      "@mekong/types/*": ["packages/types/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "build"]
}
